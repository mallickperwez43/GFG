class Solution {
  public:
    bool canFormPalindrome(string &s) {
        // code here
        vector<int> freq(26, 0);
        
        for(char& ch : s) {
            freq[ch - 'a']++;
        }
        
        int oddCount = 0;
        for(int& cur : freq) {
            if(cur & 1) {
                oddCount++;
            }
        }
        
        return (oddCount <= 1);
    }
};
