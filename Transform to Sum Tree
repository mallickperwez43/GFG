*/

class Solution {
  public:
    int solve(Node* root) {
        if(root == NULL) return 0;
        
        int curr  = root -> data;
        int left  = solve(root -> left);
        int right = solve(root -> right);
        
        root -> data = left + right;
        
        return left + right + curr;
    }
    
    void toSumTree(Node *root) {
        // code here
        if(root == NULL)
            return;
        solve(root);
    }
};
