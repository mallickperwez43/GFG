class Solution {
  public:
    vector<int> missinRange(vector<int>& arr, int low, int high) {
        // code here
        unordered_set<int> st(arr.begin(), arr.end());
        
        vector<int> result;
        for(int num = low; num <= high; num++) {
            if(!st.count(num)) 
                result.push_back(num);
        }
        return result;
    }
};
