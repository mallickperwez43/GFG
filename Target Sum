class Solution {
  public:
    int solve(int idx, int curSum, int target, vector<int>& arr, unordered_map<string, int>& dp) {
        if(idx == arr.size()) {
            if(curSum == target) {
                return 1;
            } else {
                return 0;
            }
        }    
        
        string key = to_string(idx) + '_' + to_string(curSum);
        
        if(dp.count(key)) {
            return dp[key];
        }
        
        int plus  = solve(idx + 1, curSum + arr[idx], target, arr, dp);
        int minus = solve(idx + 1, curSum - arr[idx], target, arr, dp);
        
        return dp[key] = plus + minus;
    }
    
    int totalWays(vector<int>& arr, int target) {
        //  code here
        
        unordered_map<string, int> dp;
        
        return solve(0, 0, target, arr, dp);
    }
};
