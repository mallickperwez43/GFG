class Solution {
  public:
    int coin(vector<int>& arr) {
        // code here
        int n = arr.size();
        int l = 0;
        int r = n - 1;
        
        while(l < r) {
            if(arr[l] > arr[r]) 
                l++;
            else
                r--;
        }
        
        return arr[l];
    }
};
