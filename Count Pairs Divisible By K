class Solution {
  public:
    int countKdivPairs(vector<int>& arr, int k) {
        // code here
        vector<int> freq(k, 0); // storing remainder freq
        
        int result = 0;
        
        for(int& el : arr) {
            int remain = el % k;
            
            int need = (k - remain) % k;
            
            result += freq[need];
            
            freq[remain]++;
        }
        
        return result;
    }
};
