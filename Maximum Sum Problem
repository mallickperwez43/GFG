class Solution {
  public:
    int solve(int n, unordered_map<int, int>& dp) {
        if(n == 0) return 0;
        
        if(dp.count(n)) {
            return dp[n];
        }
        
        int skip   = n;
        int divide = solve(n / 2, dp) + solve(n / 3, dp) + solve(n / 4, dp);
        
        return dp[n] = max(divide, skip);
    }
    
    int maxSum(int n) {
        // code here.
        unordered_map<int, int> dp;
        return solve(n, dp);
    }
};
