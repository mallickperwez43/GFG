class Solution {
  public:
    int getCount(int n) {
        // code here
        int count = 0;
        
        for(int k = 2; 2 * n > k * (k - 1); k++) {
            int numerator  = n - ((k * (k - 1)) / 2);
            
            if(numerator % k == 0) {
                count++;
            }
        }
        
        return count;
    }
};
