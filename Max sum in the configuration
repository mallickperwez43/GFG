class Solution {
  public:
    int maxSum(vector<int> &arr) {
        // code here
        long long n = arr.size();
        long long arraySum = 0;
        long long currentRotationSum = 0;

        // Step 1: Calculate the sum of elements and the initial R0
        for (long long i = 0; i < n; i++) {
            arraySum += arr[i];
            currentRotationSum += (i * (long long)arr[i]);
        }

        long long maxVal = currentRotationSum;

        // Step 2: Calculate subsequent rotations using the formula
        // Rj = Rj-1 + arraySum - n * arr[n-j]
        for (int j = 1; j < n; j++) {
            currentRotationSum = currentRotationSum + arraySum - (n * (long long)arr[n - j]);
            if (currentRotationSum > maxVal) {
                maxVal = currentRotationSum;
            }
        }

        return maxVal;
    }
};
