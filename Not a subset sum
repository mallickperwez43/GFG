class Solution {
  public:
    int findSmallest(vector<int> &arr) {
        // code here.
        sort(arr.begin(), arr.end());
        
        int curr = 1;
        
        for(int& num : arr) {
            if(num > curr)
                return curr;
            
            curr += num;
        }
        
        return curr;
    }
};
