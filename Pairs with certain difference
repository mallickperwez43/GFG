  public:
    int sumDiffPairs(vector<int>& arr, int k) {
        // code here
        int n = arr.size();
        
        sort(arr.begin(), arr.end());
        
        int i = n - 1;
        int sum = 0;
        
        while(i > 0) {
            if(arr[i] - arr[i - 1] < k) {
                sum += (arr[i] + arr[i - 1]);
                i -= 2;
            }
            else
                i -= 1;
        }
        
        return sum;
    }
};
