class Solution {
  public:
    string URLify(string &s) {
        // code here
        string result = "";
        
        for(char& ch : s) {
            if(ch == ' ') {
                result.push_back('%');
                result.push_back('2');
                result.push_back('0');
            }
            else 
                result.push_back(ch);
        }
        
        return result;
    }
};
